# Copy this file to .env in the repository root, then replace every placeholder.
# This repository intentionally keeps all sensitive values in ONE file: /.env

# ==========================================
# Frontend runtime settings (used by client)
# ==========================================

# 1) Deploy the signaling worker first (inside /signaling-server):
#    npm install
#    npm run deploy
# 2) Copy the final workers.dev URL from deploy output, for example:
#    wss://webrtc-signaling-server.<subdomain>.workers.dev
VITE_SIGNALING_SERVER_URL=wss://<your-worker-url>.workers.dev

# Default fallback name when user leaves "Display Name" empty.
VITE_DEFAULT_DISPLAY_NAME=Guest

# Public Cloudflare STUN endpoint.
VITE_STUN_URL=stun:stun.cloudflare.com:3478

# TURN relay URLs (comma-separated list). Keep defaults unless Cloudflare docs change.
VITE_TURN_URLS=turn:turn.cloudflare.com:3478?transport=udp,turn:turn.cloudflare.com:3478?transport=tcp,turns:turn.cloudflare.com:5349?transport=tcp,turn:turn.cloudflare.com:53?transport=udp,turn:turn.cloudflare.com:80?transport=tcp,turns:turn.cloudflare.com:443?transport=tcp

# TURN credentials for Cloudflare Realtime.
# How to get these values:
# - Open Cloudflare Dashboard and select your account.
# - Go to Realtime (Calls) TURN features and create or rotate TURN keys.
# - Generate credentials from the key (username + credential).
# - Docs entry point: https://developers.cloudflare.com/realtime/turn/
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# ========================================
# Cloudflare deployment secrets (CI or CLI)
# ========================================

# Account ID lookup guide:
# https://developers.cloudflare.com/fundamentals/account/find-account-and-zone-ids/
CLOUDFLARE_ACCOUNT_ID=

# API Token creation guide:
# https://developers.cloudflare.com/fundamentals/api/get-started/create-token/
# Minimum common scopes for this project:
# - Workers Scripts:Edit
# - Account Settings:Read
# - Cloudflare Pages:Edit (only if deploying frontend by API/CI)
CLOUDFLARE_API_TOKEN=
