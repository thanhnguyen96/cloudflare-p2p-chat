# Frontend env file (repo root: /.env)
# Only variables used by Vite client belong here.
# Worker secrets live in signaling-server/.dev.vars (local) or Wrangler secrets/vars (production).

# Required: WebSocket URL of signaling worker.
# Example: wss://webrtc-signaling-server.<subdomain>.workers.dev
VITE_SIGNALING_SERVER_URL=wss://<your-worker-url>.workers.dev

# Optional display-name fallback when user leaves input empty.
VITE_DEFAULT_DISPLAY_NAME=Guest

# Client fallback assumption if worker response omits ttl/expiresAt.
VITE_TURN_CREDENTIAL_TTL_SECONDS=3600

# Optional ICE fallback only when /api/turn-credentials is unavailable.
VITE_STUN_URL=stun:stun.cloudflare.com:3478
VITE_TURN_URLS=turn:turn.cloudflare.com:3478?transport=udp,turn:turn.cloudflare.com:3478?transport=tcp,turns:turn.cloudflare.com:5349?transport=tcp,turn:turn.cloudflare.com:53?transport=udp,turn:turn.cloudflare.com:80?transport=tcp,turns:turn.cloudflare.com:443?transport=tcp
